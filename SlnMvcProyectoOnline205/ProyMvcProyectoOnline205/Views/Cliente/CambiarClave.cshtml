@model ProyMvcProyectoOnline205.Models.CambiarClaveViewModel

@{
    Layout = "_LayoutShop";
    ViewData["Title"] = "Cambiar contrasena";
}

<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="mb-1" style="font-weight:700;color:var(--app-text)">Cambiar contrasena</h2>
            <p class="text-muted mb-0">Manten tu cuenta segura usando una contrasena fuerte.</p>
        </div>
        <a asp-action="Perfil" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver al perfil
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger" style="border-radius:10px;max-width:560px">@ViewBag.Error</div>
    }
    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success" style="border-radius:10px;max-width:560px">@TempData["mensaje"]</div>
    }

    <div class="app-card" style="max-width:560px">
        <div class="app-card__body">

            <div style="display:flex;align-items:center;gap:.75rem;padding-bottom:1rem;border-bottom:1px solid var(--app-border);margin-bottom:1.25rem">
                <span style="width:44px;height:44px;border-radius:50%;background:var(--app-info-soft);display:flex;align-items:center;justify-content:center;color:#1d4ed8">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                </span>
                <div>
                    <div style="font-weight:700">Seguridad de tu cuenta</div>
                    <div class="text-muted" style="font-size:.85rem">Usa al menos 6 caracteres con letras y numeros.</div>
                </div>
            </div>

            <form asp-action="CambiarClave" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="app-form-group">
                    <label asp-for="ClaveActual" class="app-form-label">Contrasena actual</label>
                    <input asp-for="ClaveActual" type="password" class="form-control" placeholder="••••••••" />
                </div>

                <div class="app-form-group">
                    <label asp-for="NuevaClave" class="app-form-label">Nueva contrasena</label>
                    <input asp-for="NuevaClave" type="password" class="form-control" placeholder="••••••••" />
                </div>

                <div class="app-form-group">
                    <label asp-for="ConfirmarClave" class="app-form-label">Confirmar nueva contrasena</label>
                    <input asp-for="ConfirmarClave" type="password" class="form-control" placeholder="••••••••" />
                </div>

                <div style="display:flex;justify-content:flex-end;gap:.6rem;margin-top:1rem">
                    <a asp-action="Perfil" class="app-btn app-btn--ghost">Cancelar</a>
                    <button type="submit" class="app-btn app-btn--primary">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Actualizar contrasena
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>
