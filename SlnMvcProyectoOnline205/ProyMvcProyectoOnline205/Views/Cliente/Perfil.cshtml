@model ProyMvcProyectoOnline205.Models.Cliente

@{
    Layout = "_LayoutShop";
    ViewData["Title"] = "Mi perfil";

    var iniciales = string.Concat(
        ((Model.Nombre ?? "?") + " " + (Model.Apellidos ?? "?"))
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(p => p[0])).ToUpperInvariant();
}

<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="mb-1" style="font-weight:700;color:var(--app-text)">Mi perfil</h2>
            <p class="text-muted mb-0">Administra tus datos y tu seguridad.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver al catalogo
        </a>
    </div>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success" style="border-radius:10px">@TempData["mensaje"]</div>
    }

    <div class="row g-4">

        <!-- Tarjeta perfil -->
        <div class="col-md-4">
            <div class="app-card" style="text-align:center">
                <div class="app-card__body">
                    <div style="width:88px;height:88px;border-radius:50%;background:linear-gradient(135deg,var(--app-brand),var(--app-brand-accent));color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;margin:0 auto 1rem">
                        @iniciales
                    </div>
                    <h4 style="font-weight:700;margin:.25rem 0">@Model.Nombre @Model.Apellidos</h4>
                    <p class="text-muted" style="margin-bottom:.75rem">@Model.Correo</p>
                    <span class="app-pill app-pill--success">Cliente activo</span>
                </div>
            </div>

            <div class="app-card" style="margin-top:1rem">
                <div class="app-card__body">
                    <a asp-action="CambiarClave" class="app-btn app-btn--ghost" style="width:100%;justify-content:center">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        Cambiar contrasena
                    </a>
                </div>
            </div>
        </div>

        <!-- Datos -->
        <div class="col-md-8">
            <div class="app-card">
                <div class="app-card__header">Mis datos</div>
                <div class="app-card__body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="app-form-label">Nombres</div>
                            <div>@Model.Nombre</div>
                        </div>
                        <div class="col-md-6">
                            <div class="app-form-label">Apellidos</div>
                            <div>@Model.Apellidos</div>
                        </div>
                        <div class="col-md-6">
                            <div class="app-form-label">Correo</div>
                            <div>@Model.Correo</div>
                        </div>
                        <div class="col-md-6">
                            <div class="app-form-label">Telefono</div>
                            <div>@(string.IsNullOrEmpty(Model.Telefono) ? "—" : Model.Telefono)</div>
                        </div>
                    </div>

                    <div style="display:flex;justify-content:flex-end;margin-top:1.25rem">
                        <a asp-action="EditarPerfil" class="app-btn app-btn--primary">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                            Editar perfil
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
