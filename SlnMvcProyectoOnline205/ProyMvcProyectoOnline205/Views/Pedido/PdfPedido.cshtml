@model ProyMvcProyectoOnline205.Models.Ventum
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: Arial;
            font-size: 12px;
        }

        h2 {
            text-align: center;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        th, td {
            border: 1px solid #000;
            padding: 6px;
        }

        th {
            background-color: #f2f2f2;
        }
    </style>
</head>
<body>

    <h2>Pedido #@Model.IdVenta</h2>

    <p><strong>Fecha:</strong> @Model.FechaVenta</p>
    <p><strong>Total:</strong> S/ @Model.MontoTotal</p>

    <table>
        <thead>
            <tr>
                <th>Producto</th>
                <th>Cant.</th>
                <th>Precio</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.DetalleVenta)
            {
                <tr>
                    <td>@d.IdProductoNavigation?.Nombre</td>
                    <td>@d.Cantidad</td>
                    <td>S/ @d.IdProductoNavigation?.Precio</td>
                    <td>S/ @(d.Cantidad * (d.IdProductoNavigation?.Precio ?? 0))</td>
                </tr>
            }
        </tbody>
    </table>

</body>
</html>
