@model ProyMvcProyectoOnline205.Models.Ventum
@{
    Layout = null;
    var fecha = Model.FechaVenta?.ToString("dd/MM/yyyy HH:mm") ?? "-";
    var total = (Model.MontoTotal ?? 0m).ToString("N2");
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Pedido @Model.IdVenta</title>
    <style>
        * {
            box-sizing: border-box;
        }

        @@page {
            size: A4;
            margin: 14mm;
        }

        body {
            font-family: "Segoe UI", Tahoma, Arial, sans-serif;
            font-size: 12px;
            color: #1f2937;
            margin: 0;
        }

        .ticket {
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 16px;
        }

        .header {
            display: table;
            width: 100%;
            margin-bottom: 14px;
            border-bottom: 2px solid #111827;
            padding-bottom: 10px;
        }

        .header-left,
        .header-right {
            display: table-cell;
            vertical-align: middle;
            width: 50%;
        }

        .header-right {
            text-align: right;
        }

        .brand {
            font-size: 17px;
            font-weight: 700;
            letter-spacing: 0.2px;
            color: #111827;
        }

        .muted {
            color: #6b7280;
            font-size: 11px;
        }

        .order-title {
            font-size: 19px;
            font-weight: 700;
            color: #111827;
            margin: 2px 0;
        }

        .meta {
            width: 100%;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background: #f9fafb;
            padding: 10px 12px;
            margin-bottom: 14px;
        }

        .meta-row {
            display: table;
            width: 100%;
        }

        .meta-item {
            display: table-cell;
            width: 50%;
            vertical-align: top;
        }

        .meta-label {
            font-size: 10px;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 3px;
        }

        .meta-value {
            font-size: 13px;
            font-weight: 600;
            color: #111827;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
        }

        th, td {
            border: 1px solid #d1d5db;
            padding: 8px;
            vertical-align: middle;
        }

        th {
            background-color: #f3f4f6;
            color: #111827;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        td.num,
        th.num {
            text-align: right;
            white-space: nowrap;
        }

        td.center,
        th.center {
            text-align: center;
        }

        .total-box {
            margin-top: 12px;
            display: table;
            width: 100%;
        }

        .total-line {
            display: table;
            margin-left: auto;
            min-width: 220px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            background: #f9fafb;
        }

        .total-label,
        .total-value {
            display: table-cell;
            padding: 10px 12px;
            font-size: 13px;
            font-weight: 700;
        }

        .total-label {
            color: #374151;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .total-value {
            color: #065f46;
            text-align: right;
            white-space: nowrap;
        }

        .footer {
            margin-top: 14px;
            text-align: center;
            color: #6b7280;
            font-size: 11px;
        }
    </style>
</head>
<body>
    <div class="ticket">
        <div class="header">
            <div class="header-left">
                <div class="brand">NexusShop</div>
                <div class="muted">Comprobante de pedido</div>
            </div>
            <div class="header-right">
                <div class="order-title">Pedido #@Model.IdVenta</div>
            </div>
        </div>

        <div class="meta">
            <div class="meta-row">
                <div class="meta-item">
                    <div class="meta-label">Fecha</div>
                    <div class="meta-value">@fecha</div>
                </div>
                <div class="meta-item" style="text-align:right;">
                    <div class="meta-label">Total</div>
                    <div class="meta-value">S/ @total</div>
                </div>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Producto</th>
                    <th class="center" style="width:70px;">Cant.</th>
                    <th class="num" style="width:110px;">Precio</th>
                    <th class="num" style="width:120px;">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DetalleVenta == null || !Model.DetalleVenta.Any())
                {
                    <tr>
                        <td colspan="4" style="text-align:center;color:#6b7280;">No hay productos en este pedido.</td>
                    </tr>
                }
                else
                {
                    foreach (var d in Model.DetalleVenta)
                    {
                        var precio = d.IdProductoNavigation?.Precio ?? 0m;
                        var subtotal = d.Cantidad * precio;
                        <tr>
                            <td>@(d.IdProductoNavigation?.Nombre ?? "-")</td>
                            <td class="center">@d.Cantidad</td>
                            <td class="num">S/ @precio.ToString("N2")</td>
                            <td class="num">S/ @subtotal.ToString("N2")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="total-box">
            <div class="total-line">
                <div class="total-label">Total pagado</div>
                <div class="total-value">S/ @total</div>
            </div>
        </div>

        <div class="footer">
            Gracias por tu compra.
        </div>
    </div>
</body>
</html>
