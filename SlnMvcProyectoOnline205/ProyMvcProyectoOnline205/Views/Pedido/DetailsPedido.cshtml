@model ProyMvcProyectoOnline205.Models.Ventum

@{
    var rol = Context.Session.GetInt32("IdRol");
    bool esAdmin = rol == 1 || rol == 2;
    Layout = esAdmin ? "_LayoutAdmin" : "_LayoutShop";

    ViewData["Title"]        = $"Pedido #{Model.IdVenta}";
    ViewData["PageTitle"]    = $"Pedido #{Model.IdVenta}";
    ViewData["PageSubtitle"] = "Detalle completo de la venta.";
    ViewData["PageCrumbs"]   = esAdmin
        ? new[] { "Operación", "Pedidos", $"#{Model.IdVenta}" }
        : null;

    string EstadoLabel(int? id) => id switch {
        1 => "Registrado", 2 => "Pagado", 3 => "En preparación",
        4 => "Enviado",    5 => "Entregado", 6 => "Cancelado", _ => "—"
    };
    string EstadoVariant(int? id) => id switch {
        1 => "info",  2 => "success", 3 => "warning",
        4 => "brand", 5 => "success", 6 => "danger",  _ => ""
    };

    // ── Timeline (omite paso 6 = Cancelado) ──────────────────
    var pasos = new (int Id, string Label)[] {
        (1, "Registrado"),
        (2, "Pagado"),
        (3, "Preparación"),
        (4, "Enviado"),
        (5, "Entregado"),
    };
    int estadoActual = Model.IdEstadoPedido ?? 0;
    bool estaCancelado = estadoActual == 6;

    // ── Totales ──────────────────────────────────────────────
    int totalUnidades = Model.DetalleVenta?.Sum(d => d.Cantidad) ?? 0;
    int lineas        = Model.DetalleVenta?.Count ?? 0;
}

@if (esAdmin)
{
    <partial name="Admin/_PageHeader" />
}

<style>
    /* Thumbnail de producto en tablas de pedidos */
    .prod-thumb {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        background: var(--app-surface-2);
        border: 1px solid var(--app-border);
        overflow: hidden;
        flex-shrink: 0;
        position: relative;
    }
    .prod-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .prod-thumb__fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--app-brand-accent);
        background: linear-gradient(135deg, var(--app-surface-2) 0%, rgba(99,102,241,.08) 100%);
    }
</style>

<div class="@(esAdmin ? "" : "container py-4")">

    @if (!esAdmin)
    {
        <!-- Migas + título cliente -->
        <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;font-size:.8rem;color:var(--app-text-muted)">
            <a asp-action="IndexPedido" style="color:var(--app-text-muted);display:inline-flex;align-items:center;gap:.3rem;text-decoration:none">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                Mis pedidos
            </a>
            <span style="color:var(--app-border)">/</span>
            <span>Pedido #@Model.IdVenta</span>
        </div>

        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
            <div>
                <h2 class="mb-1" style="font-weight:700;color:var(--app-text)">Pedido #@Model.IdVenta</h2>
                <p class="text-muted mb-0">Detalle completo de tu compra.</p>
            </div>
            <a asp-action="IndexPedido" class="app-btn app-btn--ghost">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
                </svg>
                Volver a mis pedidos
            </a>
        </div>
    }

    <partial name="Components/_FlashMessage" />

    <div class="row g-4">

        <!-- ════════ COLUMNA PRINCIPAL ════════ -->
        <div class="col-lg-8">

            <!-- ── HERO: Resumen del pedido ───────────────────── -->
            <div class="app-card" style="margin-bottom:1rem;overflow:hidden">
                <div style="background:linear-gradient(135deg,var(--app-brand-dark) 0%,var(--app-brand-mid) 100%);color:#fff;padding:1.5rem 1.5rem 1.25rem">
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem">
                        <div>
                            <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;color:var(--app-text-on-dark);font-weight:600;margin-bottom:.35rem">
                                Pedido
                            </div>
                            <div style="font-size:1.75rem;font-weight:800;line-height:1;margin-bottom:.5rem">
                                #@Model.IdVenta
                            </div>
                            <div style="font-size:.85rem;color:var(--app-text-on-dark);display:flex;align-items:center;gap:.4rem">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                                </svg>
                                @Model.FechaVenta?.ToString("dd 'de' MMMM 'de' yyyy · HH:mm")
                            </div>
                        </div>
                        <div style="text-align:right">
                            <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--app-text-on-dark);font-weight:600;margin-bottom:.25rem">
                                Total pagado
                            </div>
                            <div style="font-size:2rem;font-weight:800;color:#fff;line-height:1">
                                S/ @Model.MontoTotal?.ToString("N2")
                            </div>
                            <div style="margin-top:.6rem">
                                <partial name="Components/_StatusPill" model='new {
                                    variant = EstadoVariant(Model.IdEstadoPedido),
                                    text    = EstadoLabel(Model.IdEstadoPedido)
                                }' />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Timeline de estado -->
                <div style="padding:1.5rem 1.5rem 1.25rem;background:var(--app-surface)">
                    @if (estaCancelado)
                    {
                        <div style="display:flex;align-items:center;gap:.6rem;padding:.85rem 1rem;background:var(--app-danger-soft);border-radius:var(--app-radius);color:#991b1b;font-weight:600">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                            </svg>
                            Este pedido fue cancelado.
                        </div>
                    }
                    else
                    {
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:.25rem;position:relative">
                            @for (int i = 0; i < pasos.Length; i++)
                            {
                                var paso     = pasos[i];
                                var done     = paso.Id <= estadoActual;
                                var current  = paso.Id == estadoActual;
                                var bg       = done ? "var(--app-brand-accent)" : "var(--app-surface-2)";
                                var color    = done ? "#fff" : "var(--app-text-light)";
                                var border   = current ? "0 0 0 4px rgba(99,102,241,.18)" : "none";
                                var lineBg   = (i < pasos.Length - 1 && pasos[i + 1].Id <= estadoActual)
                                                ? "var(--app-brand-accent)" : "var(--app-border)";

                                <div style="flex:1;display:flex;flex-direction:column;align-items:center;position:relative;min-width:0">
                                    @if (i < pasos.Length - 1)
                                    {
                                        <div style="position:absolute;top:14px;left:50%;width:100%;height:2px;background:@lineBg;z-index:0"></div>
                                    }
                                    <div style="position:relative;z-index:1;width:30px;height:30px;border-radius:50%;background:@bg;color:@color;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;box-shadow:@border;transition:var(--app-transition)">
                                        @if (done)
                                        {
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                        }
                                        else
                                        {
                                            @(i + 1)
                                        }
                                    </div>
                                    <div style="margin-top:.5rem;font-size:.72rem;font-weight:@(current ? "700" : "500");color:@(done ? "var(--app-text)" : "var(--app-text-light)");text-align:center;line-height:1.2">
                                        @paso.Label
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="app-card__footer">
                    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
                        <a asp-action="DescargarPedido" asp-route-id="@Model.IdVenta" class="app-btn app-btn--ghost app-btn--sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                            </svg>
                            Pedido (PDF)
                        </a>
                        <a asp-action="DescargarProductosPedido" asp-route-id="@Model.IdVenta" class="app-btn app-btn--ghost app-btn--sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m7.5 4.27 9 5.15"/><path d="M21 8 12 13 3 8"/><path d="M3 8v8l9 5 9-5V8"/>
                            </svg>
                            Productos (PDF)
                        </a>
                    </div>
                </div>
            </div>

            <!-- ── PRODUCTOS ──────────────────────────────────── -->
            <div class="app-card" style="margin-bottom:1rem">
                <div class="app-card__header">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:.75rem">
                        <span style="display:inline-flex;align-items:center;gap:.5rem">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m7.5 4.27 9 5.15"/><path d="M21 8 12 13 3 8"/><path d="M3 8v8l9 5 9-5V8"/>
                            </svg>
                            Productos del pedido
                        </span>
                        <span class="app-pill">@lineas @(lineas == 1 ? "ítem" : "ítems") · @totalUnidades und.</span>
                    </div>
                </div>

                @if (Model.DetalleVenta == null || !Model.DetalleVenta.Any())
                {
                    <div class="app-card__body">
                        <div class="app-empty">
                            <div class="app-empty__title">Sin productos</div>
                            <div class="app-empty__text">No se encontraron productos en este pedido.</div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="app-table" style="border:0;border-radius:0">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th style="text-align:center;width:90px">Cant.</th>
                                    <th style="text-align:right;width:120px">Precio</th>
                                    <th style="text-align:right;width:130px">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var d in Model.DetalleVenta)
                            {
                                var prod     = d.IdProductoNavigation;
                                var precio   = prod?.Precio ?? 0;
                                var subtotal = d.Cantidad * precio;
                                var nombre   = prod?.Nombre ?? "—";
                                var marca    = prod?.IdMarcaNavigation?.Descripcion;
                                var imgSrc   = (!string.IsNullOrEmpty(prod?.RutaImagen) && !string.IsNullOrEmpty(prod?.NombreImagen))
                                                ? $"/{prod.RutaImagen}{prod.NombreImagen}".Replace("//","/")
                                                : null;
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:.75rem">
                                            <div class="prod-thumb">
                                                @if (imgSrc != null)
                                                {
                                                    <img src="@imgSrc" alt="@nombre"
                                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                                    <span class="prod-thumb__fallback" style="display:none">
                                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8 12 13 3 8"/><path d="M3 8v8l9 5 9-5V8"/></svg>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="prod-thumb__fallback">
                                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8 12 13 3 8"/><path d="M3 8v8l9 5 9-5V8"/></svg>
                                                    </span>
                                                }
                                            </div>
                                            <div style="min-width:0">
                                                <div style="font-weight:600;color:var(--app-text)">@nombre</div>
                                                @if (!string.IsNullOrEmpty(marca))
                                                {
                                                    <div class="u-text-muted" style="font-size:.75rem">@marca</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td style="text-align:center">
                                        <span class="app-pill">×@d.Cantidad</span>
                                    </td>
                                    <td style="text-align:right" class="u-text-muted">S/ @precio.ToString("N2")</td>
                                    <td style="text-align:right;font-weight:700;color:var(--app-text)">S/ @subtotal.ToString("N2")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>

                    <div class="app-card__footer">
                        <div style="display:flex;justify-content:flex-end;align-items:center;gap:1rem">
                            <span style="font-size:.85rem;color:var(--app-text-muted);font-weight:600">TOTAL</span>
                            <span style="font-size:1.35rem;font-weight:800;color:var(--app-success)">
                                S/ @Model.MontoTotal?.ToString("N2")
                            </span>
                        </div>
                    </div>
                }
            </div>

            <!-- ── CAMBIAR ESTADO (solo admin) ───────────────── -->
            @if (esAdmin)
            {
                <div class="app-card" style="margin-bottom:1rem;border-color:rgba(99,102,241,.35)">
                    <div class="app-card__header">
                        <span style="display:inline-flex;align-items:center;gap:.5rem">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                            </svg>
                            Actualizar estado del pedido
                        </span>
                    </div>
                    <div class="app-card__body">
                        <form asp-action="CambiarEstadoPedido" method="post" style="display:flex;align-items:end;gap:.75rem;flex-wrap:wrap">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="idVenta" value="@Model.IdVenta" />
                            @{
                                var estadosPedido = new Dictionary<int, string>
                                {
                                    { 1, "Registrado" },
                                    { 2, "Pagado" },
                                    { 3, "En preparación" },
                                    { 4, "Enviado" },
                                    { 5, "Entregado" },
                                    { 6, "Cancelado" }
                                };
                            }
                            <div style="flex:1;min-width:220px">
                                <label class="app-form-label" for="idEstado">Nuevo estado</label>
                                <select id="idEstado" name="idEstado" class="form-select">
                                    @foreach (var est in estadosPedido)
                                    {
                                        if (Model.IdEstadoPedido == est.Key)
                                        {
                                            <option value="@est.Key" selected>@est.Value</option>
                                        }
                                        else
                                        {
                                            <option value="@est.Key">@est.Value</option>
                                        }
                                    }
                                </select>
                            </div>
                            <button type="submit" class="app-btn app-btn--primary">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Guardar estado
                            </button>
                        </form>
                    </div>
                </div>
            }

            @if (esAdmin)
            {
                <div>
                    <a asp-action="IndexPedido" class="app-btn app-btn--ghost">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
                        </svg>
                        Volver a pedidos
                    </a>
                </div>
            }
        </div>

        <!-- ════════ COLUMNA LATERAL ════════ -->
        <div class="col-lg-4">

            <!-- Resumen rápido -->
            <div class="app-card" style="margin-bottom:1rem">
                <div class="app-card__header">Resumen</div>
                <div class="app-card__body" style="display:flex;flex-direction:column;gap:.85rem">
                    <div style="display:flex;justify-content:space-between;align-items:center">
                        <span class="u-text-muted" style="font-size:.85rem">Productos</span>
                        <span style="font-weight:600">@lineas</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center">
                        <span class="u-text-muted" style="font-size:.85rem">Unidades</span>
                        <span style="font-weight:600">@totalUnidades</span>
                    </div>
                    <hr class="u-divider" style="margin:.25rem 0" />
                    <div style="display:flex;justify-content:space-between;align-items:center">
                        <span style="font-weight:700">Total</span>
                        <span style="font-weight:800;font-size:1.15rem;color:var(--app-success)">
                            S/ @Model.MontoTotal?.ToString("N2")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Datos de envío / contacto -->
            @if (!string.IsNullOrEmpty(Model.Contacto) || !string.IsNullOrEmpty(Model.Direccion))
            {
                <div class="app-card" style="margin-bottom:1rem">
                    <div class="app-card__header">Datos de entrega</div>
                    <div class="app-card__body" style="display:flex;flex-direction:column;gap:1rem">
                        @if (!string.IsNullOrEmpty(Model.Contacto))
                        {
                            <div style="display:flex;gap:.7rem;align-items:flex-start">
                                <span style="width:34px;height:34px;border-radius:8px;background:var(--app-info-soft);color:#1d4ed8;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                                    </svg>
                                </span>
                                <div style="min-width:0">
                                    <div class="app-form-label" style="margin-bottom:.1rem">Contacto</div>
                                    <div style="font-weight:600;word-break:break-word">@Model.Contacto</div>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Direccion))
                        {
                            <div style="display:flex;gap:.7rem;align-items:flex-start">
                                <span style="width:34px;height:34px;border-radius:8px;background:rgba(99,102,241,.12);color:var(--app-brand-accent);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                                    </svg>
                                </span>
                                <div style="min-width:0">
                                    <div class="app-form-label" style="margin-bottom:.1rem">Dirección</div>
                                    <div style="font-weight:600;word-break:break-word">@Model.Direccion</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Ayuda -->
            @if (!esAdmin)
            {
                <div class="app-card" style="background:var(--app-surface-alt)">
                    <div class="app-card__body" style="text-align:center">
                        <div style="font-weight:700;margin-bottom:.25rem">¿Tienes algún problema?</div>
                        <div class="u-text-muted" style="font-size:.85rem;margin-bottom:.85rem">
                            Crea un ticket de soporte y te ayudaremos.
                        </div>
                        <a asp-controller="Ticket" asp-action="CreateTicket" class="app-btn app-btn--ghost app-btn--sm" style="width:100%;justify-content:center">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                            </svg>
                            Abrir ticket
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
