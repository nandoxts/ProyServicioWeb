@model List<ProyMvcProyectoOnline205.Models.Ventum>
@{
    Layout = null;
    var rol = Context.Session.GetInt32("IdRol");
    bool esCliente = rol == 3;

    string EstadoLabel(int? id) => id switch {
        1 => "Registrado", 2 => "Pagado", 3 => "En preparacion",
        4 => "Enviado",    5 => "Entregado", 6 => "Cancelado", _ => "-"
    };

    var totalPedidos  = Model.Count;
    var totalGastado  = Model.Sum(p => p.MontoTotal ?? 0m);
    var titulo        = esCliente ? "Mis Pedidos" : "Reporte de Pedidos";
    var subtitulo     = esCliente ? "Historial completo de tus compras" : "Listado consolidado de ventas";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@titulo</title>
    <style>
        * { box-sizing: border-box; }
        @@page { size: A4; margin: 14mm; }

        body {
            font-family: "Segoe UI", Tahoma, Arial, sans-serif;
            font-size: 11px;
            color: #1f2937;
            margin: 0;
        }

        .ticket { border: 1px solid #d1d5db; border-radius: 10px; padding: 16px; }

        .header {
            display: table; width: 100%;
            margin-bottom: 14px;
            border-bottom: 2px solid #111827;
            padding-bottom: 10px;
        }
        .header-left, .header-right { display: table-cell; vertical-align: middle; width: 50%; }
        .header-right { text-align: right; }
        .brand        { font-size: 17px; font-weight: 700; color: #111827; }
        .muted        { color: #6b7280; font-size: 11px; }
        .doc-title    { font-size: 19px; font-weight: 700; color: #111827; margin: 2px 0; }

        .meta {
            width: 100%;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background: #f9fafb;
            padding: 10px 12px;
            margin-bottom: 14px;
        }
        .meta-row  { display: table; width: 100%; }
        .meta-item { display: table-cell; width: 50%; vertical-align: top; }
        .meta-label { font-size: 10px; color: #6b7280; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 3px; }
        .meta-value { font-size: 13px; font-weight: 600; color: #111827; }
        .meta-value.success { color: #065f46; }

        table { width: 100%; border-collapse: collapse; margin-top: 8px; }
        th, td { border: 1px solid #d1d5db; padding: 7px 8px; vertical-align: middle; }
        th {
            background-color: #f3f4f6;
            color: #111827;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: .03em;
            text-align: left;
        }
        td.num, th.num    { text-align: right; white-space: nowrap; }
        td.center, th.center { text-align: center; }

        .pill {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 600;
        }
        .pill.info     { background: #dbeafe; color: #1d4ed8; }
        .pill.success  { background: #d1fae5; color: #047857; }
        .pill.warning  { background: #fef3c7; color: #92400e; }
        .pill.brand    { background: rgba(99,102,241,.15); color: #4338ca; }
        .pill.danger   { background: #fee2e2; color: #b91c1c; }
        .pill.muted    { background: #f3f4f6; color: #6b7280; }

        .totales {
            margin-top: 14px;
            display: table;
            width: 100%;
        }
        .total-line {
            display: table;
            margin-left: auto;
            min-width: 240px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            background: #f9fafb;
        }
        .total-label, .total-value {
            display: table-cell;
            padding: 10px 12px;
            font-size: 13px;
            font-weight: 700;
        }
        .total-label { color: #374151; text-transform: uppercase; letter-spacing: .04em; }
        .total-value { color: #065f46; text-align: right; white-space: nowrap; }

        .footer {
            margin-top: 14px;
            text-align: center;
            color: #6b7280;
            font-size: 11px;
        }

        @@media print { thead { display: table-header-group; } tr { page-break-inside: avoid; } }
    </style>
</head>
<body>
    <div class="ticket">
        <div class="header">
            <div class="header-left">
                <div class="brand">NexusShop</div>
                <div class="muted">@subtitulo</div>
            </div>
            <div class="header-right">
                <div class="doc-title">@titulo</div>
                <div class="muted">Generado: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>

        <div class="meta">
            <div class="meta-row">
                <div class="meta-item">
                    <div class="meta-label">Total de pedidos</div>
                    <div class="meta-value">@totalPedidos</div>
                </div>
                <div class="meta-item" style="text-align:right;">
                    <div class="meta-label">Monto acumulado</div>
                    <div class="meta-value success">S/ @totalGastado.ToString("N2")</div>
                </div>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div style="text-align:center; padding: 30px 10px; color:#6b7280;">
                No hay pedidos para mostrar.
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th style="width:60px;" class="center">N°</th>
                        <th style="width:110px;">Fecha</th>
                        @if (!esCliente)
                        {
                            <th style="width:60px;" class="center">Cliente</th>
                        }
                        <th>Contacto / Direccion</th>
                        <th style="width:100px;" class="center">Estado</th>
                        <th class="num" style="width:90px;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.OrderByDescending(p => p.FechaVenta))
                    {
                        var variant = (p.IdEstadoPedido) switch {
                            1 => "info", 2 => "success", 3 => "warning",
                            4 => "brand", 5 => "success", 6 => "danger", _ => "muted"
                        };
                        <tr>
                            <td class="center" style="color:#6b7280; font-weight:600;">#@p.IdVenta</td>
                            <td>@p.FechaVenta?.ToString("dd/MM/yyyy HH:mm")</td>
                            @if (!esCliente)
                            {
                                <td class="center">#@p.IdCliente</td>
                            }
                            <td>
                                <div style="font-weight:600;">@(p.Contacto ?? "-")</div>
                                @if (!string.IsNullOrEmpty(p.Direccion))
                                {
                                    <div class="muted">@p.Direccion</div>
                                }
                            </td>
                            <td class="center"><span class="pill @variant">@EstadoLabel(p.IdEstadoPedido)</span></td>
                            <td class="num" style="font-weight:700;">S/ @((p.MontoTotal ?? 0m).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="totales">
                <div class="total-line">
                    <div class="total-label">Monto total</div>
                    <div class="total-value">S/ @totalGastado.ToString("N2")</div>
                </div>
            </div>
        }

        <div class="footer">
            NexusShop · Documento generado automáticamente
        </div>
    </div>
</body>
</html>
