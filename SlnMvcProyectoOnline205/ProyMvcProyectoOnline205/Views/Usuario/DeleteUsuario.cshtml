@model ProyMvcProyectoOnline205.Models.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<h1 class="text-danger">Eliminar Usuario</h1>

<div class="alert alert-warning">
    ¿Está seguro que desea desactivar este usuario?
</div>

<dl class="row">
    <dt class="col-sm-3">Usuario</dt>
    <dd class="col-sm-9">@Model.Nombres @Model.Apellidos</dd>

    <dt class="col-sm-3">Correo</dt>
    <dd class="col-sm-9">@Model.Correo</dd>

    <dt class="col-sm-3">Rol</dt>
    <dd class="col-sm-9">@Model.IdRol</dd>
</dl>

<form asp-action="DeleteUsuario" method="post">
    <input type="hidden" asp-for="IdUsuario" />

    <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
    <a asp-action="IndexUsuario" class="btn btn-secondary">Cancelar</a>
</form>
