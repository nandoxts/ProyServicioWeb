@model ProyMvcProyectoOnline205.Models.Usuario

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"]        = "Eliminar usuario";
    ViewData["PageTitle"]    = "Eliminar usuario";
    ViewData["PageSubtitle"] = "Esta acción desactiva al usuario (eliminación lógica).";
    ViewData["PageCrumbs"]   = new[] { "Personas", "Usuarios", "Eliminar" };

    string RolLabel(int? r) => r switch { 1 => "Administrador", 2 => "Vendedor", _ => "—" };

    ViewData["PageActions"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <a asp-action="IndexUsuario" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver
        </a>
    </text>);
}

<partial name="Admin/_PageHeader" />

<div class="app-card" style="max-width:720px">
    <div class="app-card__body">

        <!-- Banner de advertencia -->
        <div style="display:flex;gap:.85rem;padding:1rem;border-radius:10px;background:var(--app-warning-soft);border:1px solid rgba(217,119,6,.25);margin-bottom:1.25rem">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#92400e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <div>
                <div style="font-weight:700;color:#92400e">¿Eliminar a este usuario?</div>
                <div class="app-form-help" style="color:#92400e">El usuario quedará desactivado y no podrá iniciar sesión. Esta acción se puede revertir desde la edición.</div>
            </div>
        </div>

        <!-- Resumen -->
        <div class="row g-3" style="margin-bottom:1.25rem">
            <div class="col-md-6">
                <div class="app-form-label">Usuario</div>
                <div>@Model.Nombres @Model.Apellidos</div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Correo</div>
                <div>@Model.Correo</div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Rol</div>
                <div><span class="app-pill app-pill--brand">@RolLabel(Model.IdRol)</span></div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Estado actual</div>
                <div><partial name="Components/_StatusPill" model='new { active = Model.Activo }' /></div>
            </div>
        </div>

        <!-- Acciones -->
        <form asp-action="DeleteUsuario" method="post" style="display:flex;justify-content:flex-end;gap:.6rem;border-top:1px solid var(--app-border);padding-top:1.25rem">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdUsuario" />
            <a asp-action="IndexUsuario" class="app-btn app-btn--ghost">Cancelar</a>
            <button type="submit" class="app-btn app-btn--danger">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                </svg>
                Confirmar eliminación
            </button>
        </form>

    </div>
</div>
