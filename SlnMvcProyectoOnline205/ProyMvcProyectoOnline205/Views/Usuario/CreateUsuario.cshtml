@model ProyMvcProyectoOnline205.Models.Usuario

@{
    ViewData["Title"] = "Crear Usuario";
}

<h1>Registrar Usuario</h1>

<hr />

<form asp-action="CreateUsuario" method="post">
    <div class="form-group mb-3">
        <label asp-for="IdRol"></label>
        <input asp-for="IdRol" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Nombres"></label>
        <input asp-for="Nombres" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Apellidos"></label>
        <input asp-for="Apellidos" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Correo"></label>
        <input asp-for="Correo" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="PasswordHash"></label>
        <input asp-for="PasswordHash" class="form-control" type="password" />
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="IndexUsuario" class="btn btn-secondary">Cancelar</a>
</form>
