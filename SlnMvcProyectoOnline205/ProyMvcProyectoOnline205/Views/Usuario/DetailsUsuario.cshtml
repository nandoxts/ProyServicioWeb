@model ProyMvcProyectoOnline205.Models.Usuario

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"]        = "Detalle de usuario";
    ViewData["PageTitle"]    = $"{Model.Nombres} {Model.Apellidos}";
    ViewData["PageSubtitle"] = "Información completa del usuario.";
    ViewData["PageCrumbs"]   = new[] { "Personas", "Usuarios", "Detalle" };

    string RolLabel(int? r) => r switch { 1 => "Administrador", 2 => "Vendedor", _ => "—" };

    ViewData["PageActions"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <a asp-action="IndexUsuario" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver
        </a>
        <a asp-action="EditUsuario" asp-route-id="@Model.IdUsuario" class="app-btn app-btn--primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Editar
        </a>
    </text>);

    var iniciales = string.Concat(
        ((Model.Nombres ?? "?") + " " + (Model.Apellidos ?? "?"))
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(p => p[0])).ToUpperInvariant();
}

<partial name="Admin/_PageHeader" />

<div class="app-card" style="max-width:880px">
    <div class="app-card__body">

        <!-- Cabecera con avatar -->
        <div style="display:flex;align-items:center;gap:1rem;padding-bottom:1rem;border-bottom:1px solid var(--app-border);margin-bottom:1.25rem">
            <span class="admin-topbar__avatar" style="width:56px;height:56px;font-size:1.1rem">@iniciales</span>
            <div>
                <div style="font-size:1.05rem;font-weight:700;color:var(--app-text)">@Model.Nombres @Model.Apellidos</div>
                <div class="u-text-muted">@Model.Correo</div>
            </div>
            <div style="margin-left:auto;display:flex;gap:.4rem;flex-wrap:wrap">
                <span class="app-pill app-pill--brand">@RolLabel(Model.IdRol)</span>
                <partial name="Components/_StatusPill" model='new { active = Model.Activo }' />
            </div>
        </div>

        <!-- Datos en grid -->
        <div class="row g-3">
            <div class="col-md-6">
                <div class="app-form-label">ID</div>
                <div>#@Model.IdUsuario</div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Rol</div>
                <div>@RolLabel(Model.IdRol)</div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Nombres</div>
                <div>@Model.Nombres</div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Apellidos</div>
                <div>@Model.Apellidos</div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Correo</div>
                <div>@Model.Correo</div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">¿Restablecer contraseña?</div>
                <div>
                    <partial name="Components/_StatusPill" model='new {
                        active   = Model.Reestablecer,
                        variant  = Model.Reestablecer == true ? "warning" : null,
                        labelOn  = "Sí",
                        labelOff = "No"
                    }' />
                </div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Estado</div>
                <div><partial name="Components/_StatusPill" model='new { active = Model.Activo }' /></div>
            </div>
            <div class="col-md-6">
                <div class="app-form-label">Fecha de registro</div>
                <div>@Model.FechaRegistro?.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>

    </div>
</div>
