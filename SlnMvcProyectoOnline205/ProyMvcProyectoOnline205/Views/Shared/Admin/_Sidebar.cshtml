@*
    Partial: _Sidebar (admin)
    --------------------------------------------------------------
    Sidebar de navegación del panel admin. Iconos SVG inline.
    Marca el link activo según el controller actual.
*@

@{
    var currentController = (ViewContext.RouteData.Values["controller"] as string ?? "").ToLowerInvariant();
    bool IsActive(params string[] controllers) =>
        controllers.Any(c => c.Equals(currentController, StringComparison.OrdinalIgnoreCase));
}

<aside class="admin-sidebar" aria-label="Navegación principal">

    <a class="admin-sidebar__brand" asp-controller="Home" asp-action="Index">
        <span class="admin-sidebar__brand-mark" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12 12 3l9 9"/><path d="M5 10v10h14V10"/>
            </svg>
        </span>
        <span class="admin-sidebar__brand-text">
            NexusShop
            <small>Admin Panel</small>
        </span>
    </a>

    <nav class="admin-sidebar__nav">

        <div class="admin-sidebar__heading">General</div>

        <a class="admin-sidebar__link @(IsActive("Dashboard") ? "is-active" : "")"
           asp-controller="Dashboard" asp-action="Index">
            <span class="admin-sidebar__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/>
                    <rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/>
                </svg>
            </span>
            <span class="admin-sidebar__label">Dashboard</span>
        </a>

        <div class="admin-sidebar__heading">Catálogo</div>

        <a class="admin-sidebar__link @(IsActive("Producto") ? "is-active" : "")"
           asp-controller="Producto" asp-action="IndexProducto">
            <span class="admin-sidebar__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m7.5 4.27 9 5.15"/><path d="M21 8 12 13 3 8"/><path d="M3 8v8l9 5 9-5V8"/>
                    <path d="M12 22V13"/>
                </svg>
            </span>
            <span class="admin-sidebar__label">Productos</span>
        </a>

        <div class="admin-sidebar__heading">Operación</div>

        <a class="admin-sidebar__link @(IsActive("Pedido") ? "is-active" : "")"
           asp-controller="Pedido" asp-action="IndexAdmin">
            <span class="admin-sidebar__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/>
                </svg>
            </span>
            <span class="admin-sidebar__label">Pedidos</span>
        </a>

        <a class="admin-sidebar__link @(IsActive("Ticket") ? "is-active" : "")"
           asp-controller="Ticket" asp-action="IndexTicket">
            <span class="admin-sidebar__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 9.5V7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v2.5a2.5 2.5 0 0 0 0 5V17a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-2.5a2.5 2.5 0 0 0 0-5Z"/>
                    <path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/>
                </svg>
            </span>
            <span class="admin-sidebar__label">Tickets</span>
        </a>

        <a class="admin-sidebar__link @(IsActive("Notificacion") ? "is-active" : "")"
           asp-controller="Notificacion" asp-action="Index">
            <span class="admin-sidebar__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                    <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
                </svg>
            </span>
            <span class="admin-sidebar__label">Notificaciones</span>
            @await Component.InvokeAsync("AdminNotificationBadge")
        </a>

        <div class="admin-sidebar__heading">Personas</div>

        <a class="admin-sidebar__link @(IsActive("Cliente") ? "is-active" : "")"
           asp-controller="Cliente" asp-action="IndexCliente">
            <span class="admin-sidebar__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </span>
            <span class="admin-sidebar__label">Clientes</span>
        </a>

        <a class="admin-sidebar__link @(IsActive("Usuario") ? "is-active" : "")"
           asp-controller="Usuario" asp-action="IndexUsuario">
            <span class="admin-sidebar__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="10" cy="7" r="4"/>
                    <path d="M22 11h-6"/><path d="M19 8v6"/>
                </svg>
            </span>
            <span class="admin-sidebar__label">Usuarios</span>
        </a>

    </nav>

    <div class="admin-sidebar__footer">
        <div>v1.0 · @DateTime.Now.Year</div>
    </div>

</aside>
