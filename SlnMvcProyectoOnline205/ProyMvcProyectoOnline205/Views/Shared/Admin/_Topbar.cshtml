@*
    Partial: _Topbar (admin)
    --------------------------------------------------------------
    Topbar fija con: toggle sidebar, título de la página actual,
    icono de notificaciones, y menú de usuario con avatar.
*@
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var nombre   = HttpContextAccessor.HttpContext?.Session.GetString("Nombre") ?? "Admin";
    var correo   = HttpContextAccessor.HttpContext?.Session.GetString("Correo") ?? "";
    var idRol    = HttpContextAccessor.HttpContext?.Session.GetInt32("IdRol");
    var rolLabel = idRol switch { 1 => "Administrador", 2 => "Vendedor", _ => "Usuario" };
    var iniciales = string.IsNullOrWhiteSpace(nombre)
        ? "AD"
        : string.Concat(nombre.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(p => p[0])).ToUpperInvariant();
    var pageTitle = ViewData["Title"] as string ?? "";
}

<header class="admin-topbar">

    <button type="button" class="admin-topbar__toggle"
            data-admin-toggle aria-label="Alternar menú">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <h1 class="admin-topbar__title">@pageTitle</h1>

    <div class="admin-topbar__spacer"></div>

    <a class="admin-topbar__icon-btn" asp-controller="Notificacion" asp-action="Index"
       title="Notificaciones" aria-label="Notificaciones">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
            <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
        </svg>
        @if (ViewBag.NotificacionesNoLeidas != null && (int)ViewBag.NotificacionesNoLeidas > 0)
        {
            <span class="admin-topbar__dot" aria-hidden="true"></span>
        }
    </a>

    <div class="dropdown">
        <a class="admin-topbar__user" data-bs-toggle="dropdown" role="button" aria-expanded="false">
            <span class="admin-topbar__avatar">@iniciales</span>
            <span class="admin-topbar__user-meta">
                <strong>@nombre</strong>
                <small>@rolLabel</small>
            </span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
            @if (!string.IsNullOrEmpty(correo))
            {
                <li><span class="dropdown-item-text small text-muted">@correo</span></li>
                <li><hr class="dropdown-divider" /></li>
            }
            <li>
                <a class="dropdown-item" asp-controller="Autenticacion" asp-action="Logout">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Cerrar sesión
                </a>
            </li>
        </ul>
    </div>

</header>
