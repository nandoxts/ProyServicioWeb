@model ProyMvcProyectoOnline205.Models.Producto

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"]        = "Detalle de producto";
    ViewData["PageTitle"]    = Model.Nombre ?? "Producto";
    ViewData["PageSubtitle"] = "Informacion completa del producto.";
    ViewData["PageCrumbs"]   = new[] { "Catalogo", "Productos", "Detalle" };

    ViewData["PageActions"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <a asp-action="IndexProducto" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver
        </a>
        <a asp-action="EditProducto" asp-route-id="@Model.IdProducto" class="app-btn app-btn--primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Editar
        </a>
    </text>);
}

<partial name="Admin/_PageHeader" />

<div class="row g-4" style="max-width:1100px">

    <!-- Imagen -->
    <div class="col-md-4">
        <div class="app-card">
            <div class="app-card__body" style="text-align:center">
                @if (!string.IsNullOrEmpty(Model.RutaImagen))
                {
                    <img src="@Model.RutaImagen" alt="@Model.Nombre" style="max-width:100%;max-height:280px;border-radius:8px" />
                }
                else
                {
                    <div style="width:100%;height:220px;background:var(--app-surface-alt);border-radius:10px;display:flex;align-items:center;justify-content:center;color:var(--app-text-muted)">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                        </svg>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Datos -->
    <div class="col-md-8">
        <div class="app-card">
            <div class="app-card__body">

                <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap">
                    <h3 style="margin:0;font-weight:700;color:var(--app-text)">@Model.Nombre</h3>
                    <partial name="Components/_StatusPill" model='new { active = Model.Activo }' />
                </div>

                <div style="font-size:1.6rem;font-weight:800;color:var(--app-brand-accent);margin-bottom:1rem">
                    S/ @(Model.Precio?.ToString("N2") ?? "0.00")
                </div>

                <p class="text-muted">@Model.Descripcion</p>

                <hr />

                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="app-form-label">ID</div>
                        <div>#@Model.IdProducto</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="app-form-label">Stock disponible</div>
                        <div>
                            @if ((Model.Stock ?? 0) > 0)
                            {
                                <span class="app-pill app-pill--success">@Model.Stock unidades</span>
                            }
                            else
                            {
                                <span class="app-pill app-pill--danger">Sin stock</span>
                            }
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="app-form-label">Categoria</div>
                        <div>@(Model.IdCategoriaNavigation?.Descripcion ?? $"#{Model.IdCategoria}")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="app-form-label">Marca</div>
                        <div>@(Model.IdMarcaNavigation?.Descripcion ?? $"#{Model.IdMarca}")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="app-form-label">Fecha de registro</div>
                        <div>@Model.FechaRegistro?.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
