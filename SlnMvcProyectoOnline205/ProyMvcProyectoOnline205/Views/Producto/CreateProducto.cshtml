@model ProyMvcProyectoOnline205.Models.Producto
@using ProyMvcProyectoOnline205.Models

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"]        = "Nuevo producto";
    ViewData["PageTitle"]    = "Registrar producto";
    ViewData["PageSubtitle"] = "Agrega un nuevo articulo al catalogo.";
    ViewData["PageCrumbs"]   = new[] { "Catalogo", "Productos", "Nuevo" };

    var categorias = ViewBag.Categorias as List<Categorium> ?? new List<Categorium>();
    var marcas     = ViewBag.Marcas     as List<Marca>      ?? new List<Marca>();

    ViewData["PageActions"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <a asp-action="IndexProducto" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver a la lista
        </a>
    </text>);
}

<partial name="Admin/_PageHeader" />

<div class="app-card" style="max-width:960px">
    <div class="app-card__header">Datos del producto</div>
    <div class="app-card__body">

        <form asp-action="CreateProducto" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger app-form-help" style="margin-bottom:1rem"></div>

            <div class="row g-3">

                <div class="col-md-8 app-form-group">
                    <label asp-for="Nombre" class="app-form-label">Nombre</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej. Laptop Lenovo IdeaPad 3" />
                    <span asp-validation-for="Nombre" class="text-danger app-form-help"></span>
                </div>

                <div class="col-md-4 app-form-group">
                    <label asp-for="Stock" class="app-form-label">Stock inicial</label>
                    <input asp-for="Stock" type="number" min="0" class="form-control" placeholder="0" />
                    <span asp-validation-for="Stock" class="text-danger app-form-help"></span>
                </div>

                <div class="col-md-12 app-form-group">
                    <label asp-for="Descripcion" class="app-form-label">Descripcion</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Detalle del producto"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger app-form-help"></span>
                </div>

                <div class="col-md-4 app-form-group">
                    <label asp-for="Precio" class="app-form-label">Precio (S/)</label>
                    <input asp-for="Precio" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                    <span asp-validation-for="Precio" class="text-danger app-form-help"></span>
                </div>

                <div class="col-md-4 app-form-group">
                    <label asp-for="IdCategoria" class="app-form-label">Categoria</label>
                    <select asp-for="IdCategoria" class="form-select">
                        <option value="">Selecciona…</option>
                        @foreach (var c in categorias)
                        {
                            <option value="@c.IdCategoria">@c.Descripcion</option>
                        }
                    </select>
                </div>

                <div class="col-md-4 app-form-group">
                    <label asp-for="IdMarca" class="app-form-label">Marca</label>
                    <select asp-for="IdMarca" class="form-select">
                        <option value="">Selecciona…</option>
                        @foreach (var m in marcas)
                        {
                            <option value="@m.IdMarca">@m.Descripcion</option>
                        }
                    </select>
                </div>

                <div class="col-md-12 app-form-group">
                    <label class="app-form-label">Imagen del producto <span class="text-muted" style="font-weight:400">(opcional · JPG, PNG, GIF o WEBP · max 5 MB)</span></label>
                    <div class="app-uploader" id="uploaderCreate">
                        <label class="app-uploader__drop" for="imagenArchivo">
                            <div class="app-uploader__preview" id="previewCreate">
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                                    <circle cx="8.5" cy="8.5" r="1.5"/>
                                    <polyline points="21 15 16 10 5 21"/>
                                </svg>
                                <span class="app-uploader__hint">Click o arrastra una imagen aqui</span>
                                <span class="app-uploader__filename" id="fileNameCreate"></span>
                            </div>
                            <input type="file" id="imagenArchivo" name="imagenArchivo" accept="image/*" class="app-uploader__input" />
                        </label>
                        <button type="button" class="app-btn app-btn--ghost app-uploader__clear" id="clearCreate" hidden>
                            Quitar imagen
                        </button>
                    </div>
                </div>

            </div>

            <div style="display:flex;justify-content:flex-end;gap:.6rem;margin-top:1.5rem">
                <a asp-action="IndexProducto" class="app-btn app-btn--ghost">Cancelar</a>
                <button type="submit" class="app-btn app-btn--primary">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Guardar producto
                </button>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        (function () {
            var input    = document.getElementById('imagenArchivo');
            var preview  = document.getElementById('previewCreate');
            var fileName = document.getElementById('fileNameCreate');
            var clearBtn = document.getElementById('clearCreate');
            if (!input) return;

            function reset() {
                input.value = '';
                preview.classList.remove('is-loaded');
                preview.style.backgroundImage = '';
                fileName.textContent = '';
                clearBtn.hidden = true;
            }

            input.addEventListener('change', function () {
                var f = input.files && input.files[0];
                if (!f) { reset(); return; }
                if (!f.type.startsWith('image/')) {
                    alert('El archivo debe ser una imagen.');
                    reset(); return;
                }
                if (f.size > 5 * 1024 * 1024) {
                    alert('La imagen supera los 5 MB.');
                    reset(); return;
                }
                var reader = new FileReader();
                reader.onload = function (e) {
                    preview.style.backgroundImage = 'url(' + e.target.result + ')';
                    preview.classList.add('is-loaded');
                    fileName.textContent = f.name;
                    clearBtn.hidden = false;
                };
                reader.readAsDataURL(f);
            });

            clearBtn.addEventListener('click', reset);
        })();
    </script>
}
