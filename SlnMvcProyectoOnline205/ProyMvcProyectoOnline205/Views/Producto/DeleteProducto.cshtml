@model ProyMvcProyectoOnline205.Models.Producto

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"]        = "Eliminar producto";
    ViewData["PageTitle"]    = "Eliminar producto";
    ViewData["PageSubtitle"] = "Esta accion desactiva el producto del catalogo (eliminacion logica).";
    ViewData["PageCrumbs"]   = new[] { "Catalogo", "Productos", "Eliminar" };

    ViewData["PageActions"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <a asp-action="IndexProducto" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver
        </a>
    </text>);
}

<partial name="Admin/_PageHeader" />

<div class="app-card" style="max-width:760px">
    <div class="app-card__body">

        <!-- Banner -->
        <div style="display:flex;gap:.85rem;padding:1rem;border-radius:10px;background:var(--app-warning-soft);border:1px solid rgba(217,119,6,.25);margin-bottom:1.25rem">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#92400e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <div>
                <div style="font-weight:700;color:#92400e">Eliminar este producto?</div>
                <div class="app-form-help" style="color:#92400e">
                    El producto sera marcado como inactivo y dejara de aparecer en el catalogo. Esta accion se puede revertir desde la edicion.
                </div>
            </div>
        </div>

        <!-- Resumen -->
        <div style="display:flex;gap:1rem;padding:1rem;border:1px solid var(--app-border);border-radius:10px;margin-bottom:1.25rem;align-items:center">
            <div style="flex-shrink:0;width:72px;height:72px;border-radius:10px;background:var(--app-surface-alt);display:flex;align-items:center;justify-content:center;overflow:hidden">
                @if (!string.IsNullOrEmpty(Model.RutaImagen))
                {
                    <img src="@Model.RutaImagen" alt="@Model.Nombre" style="width:100%;height:100%;object-fit:cover" />
                }
                else
                {
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--app-text-muted)">
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                        <circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                    </svg>
                }
            </div>
            <div style="flex:1">
                <div style="font-weight:700">@Model.Nombre</div>
                <div class="text-muted" style="font-size:.85rem">@Model.Descripcion</div>
                <div style="margin-top:.4rem;display:flex;gap:.4rem;flex-wrap:wrap">
                    <span class="app-pill app-pill--brand">S/ @(Model.Precio?.ToString("N2") ?? "0.00")</span>
                    <span class="app-pill">@(Model.Stock ?? 0) en stock</span>
                </div>
            </div>
        </div>

        <!-- Acciones -->
        <form asp-action="DeleteProducto" method="post" style="display:flex;justify-content:flex-end;gap:.6rem;border-top:1px solid var(--app-border);padding-top:1.25rem">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.IdProducto" />
            <a asp-action="IndexProducto" class="app-btn app-btn--ghost">Cancelar</a>
            <button type="submit" class="app-btn app-btn--danger">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                </svg>
                Confirmar eliminacion
            </button>
        </form>

    </div>
</div>
