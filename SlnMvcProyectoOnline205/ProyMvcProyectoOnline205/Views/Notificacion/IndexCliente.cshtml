@model IEnumerable<ProyMvcProyectoOnline205.Models.NotificacionCliente>

@{
    Layout = "_LayoutShop";
    ViewData["Title"] = "Mis notificaciones";

    var noLeidas = Model.Count(n => n.EsLeido != true);
}

<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="mb-1" style="font-weight:700;color:var(--app-text)">Mis notificaciones</h2>
            <p class="text-muted mb-0">
                @(noLeidas > 0
                    ? $"Tienes {noLeidas} {(noLeidas == 1 ? "notificacion" : "notificaciones")} sin leer."
                    : "Estas al dia.")
            </p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver al catalogo
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="app-card" style="text-align:center;padding:3rem 1.5rem">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--app-text-muted);margin-bottom:1rem">
                <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
            </svg>
            <h4 style="font-weight:600">Sin notificaciones</h4>
            <p class="text-muted">Cuando recibas una respuesta o aviso, lo veras aqui.</p>
        </div>
    }
    else
    {
        <div class="app-card">
            <div class="app-card__body" style="padding:0">
                @foreach (var n in Model.OrderByDescending(x => x.FechaCreacion))
                {
                    var leida = n.EsLeido == true;
                    <div style="display:flex;gap:.85rem;padding:1rem 1.25rem;border-bottom:1px solid var(--app-border);@(leida ? "" : "background:rgba(99,102,241,.05);")">

                        <span style="flex-shrink:0;width:36px;height:36px;border-radius:50%;
                                     background:@(leida ? "var(--app-surface-alt)" : "var(--app-info-soft)");
                                     color:@(leida ? "var(--app-text-muted)" : "#1d4ed8");
                                     display:flex;align-items:center;justify-content:center">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                                <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
                            </svg>
                        </span>

                        <div style="flex:1;min-width:0">
                            <div style="@(leida ? "" : "font-weight:600;")">@n.Mensaje</div>
                            <div class="text-muted" style="font-size:.78rem;margin-top:.2rem">
                                @n.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>

                        <div style="flex-shrink:0">
                            @if (leida)
                            {
                                <span class="app-pill app-pill--success">Leida</span>
                            }
                            else
                            {
                                <span class="app-pill app-pill--brand">Nueva</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
