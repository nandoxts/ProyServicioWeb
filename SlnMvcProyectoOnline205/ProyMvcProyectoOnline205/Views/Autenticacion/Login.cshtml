@{
    Layout = null;
    ViewData["Title"] = "Iniciar sesion";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Iniciar sesion — NexusShop</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@@300;400;500;600;700;800&display=swap');

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            height: 100vh;
            display: flex;
            overflow: hidden;
            background: #0f172a;
            -webkit-font-smoothing: antialiased;
        }

        /* ── PANEL IZQUIERDO (branding) ── */
        .login-brand {
            flex: 1;
            background: linear-gradient(145deg, #1e1b4b 0%, #312e81 50%, #4338ca 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem 4rem;
            position: relative;
            overflow: hidden;
        }
        .login-brand::before {
            content: '';
            position: absolute;
            width: 500px; height: 500px;
            border-radius: 50%;
            background: rgba(99,102,241,.15);
            top: -150px; right: -150px;
        }
        .login-brand::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            border-radius: 50%;
            background: rgba(99,102,241,.1);
            bottom: -80px; left: -80px;
        }
        .brand-logo {
            font-size: 2rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -.04em;
            margin-bottom: 2.5rem;
            position: relative;
            z-index: 1;
        }
        .brand-logo span { color: #a5b4fc; }
        .brand-tagline {
            font-size: 2.4rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
            letter-spacing: -.03em;
            margin-bottom: 1rem;
            position: relative;
            z-index: 1;
        }
        .brand-sub {
            color: #a5b4fc;
            font-size: .95rem;
            line-height: 1.7;
            max-width: 340px;
            position: relative;
            z-index: 1;
        }
        .brand-features {
            margin-top: 3rem;
            display: flex;
            flex-direction: column;
            gap: .85rem;
            position: relative;
            z-index: 1;
        }
        .brand-feature {
            display: flex;
            align-items: center;
            gap: .75rem;
            color: #c7d2fe;
            font-size: .875rem;
            font-weight: 500;
        }
        .brand-feature-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: #818cf8;
            flex-shrink: 0;
        }

        /* ── PANEL DERECHO (formulario) ── */
        .login-form-panel {
            width: 480px;
            flex-shrink: 0;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem 3.5rem;
            overflow-y: auto;
        }

        .form-header { margin-bottom: 2.5rem; }
        .form-header h1 {
            font-size: 1.75rem;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -.03em;
            margin-bottom: .4rem;
        }
        .form-header p {
            color: #64748b;
            font-size: .9rem;
        }

        .form-label {
            font-size: .8rem;
            font-weight: 600;
            letter-spacing: .03em;
            text-transform: uppercase;
            color: #475569;
            margin-bottom: .4rem;
        }
        .form-control {
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: .75rem 1rem;
            font-size: .9375rem;
            font-family: 'Inter', sans-serif;
            color: #0f172a;
            transition: border-color .15s ease, box-shadow .15s ease;
            background: #f8fafc;
        }
        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,.12);
            background: #fff;
            outline: none;
        }
        .form-control::placeholder { color: #94a3b8; }

        .password-wrap { position: relative; }
        .password-toggle {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
        }
        .password-toggle:hover { color: #6366f1; }

        .btn-login {
            width: 100%;
            background: #6366f1;
            border: none;
            border-radius: 10px;
            padding: .85rem;
            font-size: .9375rem;
            font-weight: 700;
            color: #fff;
            cursor: pointer;
            transition: background .2s ease, transform .1s ease;
            font-family: 'Inter', sans-serif;
            letter-spacing: -.01em;
            margin-top: .5rem;
        }
        .btn-login:hover { background: #4f46e5; }
        .btn-login:active { transform: scale(.99); }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.5rem 0;
            color: #cbd5e1;
            font-size: .8rem;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-top: 1px solid #e2e8f0;
        }

        .btn-register {
            width: 100%;
            background: transparent;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: .75rem;
            font-size: .875rem;
            font-weight: 600;
            color: #475569;
            cursor: pointer;
            transition: all .2s ease;
            font-family: 'Inter', sans-serif;
            text-decoration: none;
            display: block;
            text-align: center;
        }
        .btn-register:hover {
            border-color: #6366f1;
            color: #6366f1;
            background: rgba(99,102,241,.04);
        }

        .error-box {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: .75rem 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: .6rem;
            color: #dc2626;
            font-size: .875rem;
            font-weight: 500;
        }

        .back-shop {
            margin-top: 2rem;
            text-align: center;
            font-size: .82rem;
            color: #94a3b8;
        }
        .back-shop a {
            color: #6366f1;
            text-decoration: none;
            font-weight: 600;
        }
        .back-shop a:hover { text-decoration: underline; }

        @@media (max-width: 768px) {
            .login-brand { display: none; }
            .login-form-panel { width: 100%; padding: 2rem 1.5rem; }
        }
    </style>
</head>
<body>

    <!-- PANEL IZQUIERDO -->
    <div class="login-brand">
        <div class="brand-logo">Nexus<span>Shop</span></div>
        <h2 class="brand-tagline">Tu tienda,<br />tu manera.</h2>
        <p class="brand-sub">
            Accede a tu cuenta para gestionar pedidos, hacer seguimiento de tus compras y mucho mas.
        </p>
        <div class="brand-features">
            <div class="brand-feature">
                <span class="brand-feature-dot"></span>
                Catalogo de productos actualizado
            </div>
            <div class="brand-feature">
                <span class="brand-feature-dot"></span>
                Seguimiento de pedidos en tiempo real
            </div>
            <div class="brand-feature">
                <span class="brand-feature-dot"></span>
                Soporte y tickets de atencion
            </div>
            <div class="brand-feature">
                <span class="brand-feature-dot"></span>
                Notificaciones instantaneas
            </div>
        </div>
    </div>

    <!-- PANEL DERECHO (formulario) -->
    <div class="login-form-panel">

        <div class="form-header">
            <h1>Bienvenido de vuelta</h1>
            <p>Ingresa tus credenciales para continuar</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                </svg>
                @ViewBag.Error
            </div>
        }

        <form method="post">
            <div class="mb-4">
                <label class="form-label">Correo electronico</label>
                <input name="correo"
                       type="email"
                       class="form-control"
                       placeholder="tu@correo.com"
                       required
                       autocomplete="email" />
            </div>

            <div class="mb-4">
                <label class="form-label">Contrasena</label>
                <div class="password-wrap">
                    <input name="password"
                           id="passwordInput"
                           type="password"
                           class="form-control"
                           placeholder="••••••••"
                           required
                           autocomplete="current-password"
                           style="padding-right: 3rem;" />
                    <button type="button" class="password-toggle" onclick="togglePassword()" title="Mostrar/ocultar">
                        <svg id="iconEye" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                        </svg>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-login">Ingresar</button>
        </form>

        <div class="divider">o</div>

        <a asp-action="Registro" class="btn-register">Crear una cuenta nueva</a>

        <div class="back-shop">
            <a asp-controller="Home" asp-action="Index">Volver a la tienda</a>
        </div>

    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>

</body>
</html>
