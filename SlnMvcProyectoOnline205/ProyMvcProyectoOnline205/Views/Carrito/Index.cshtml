@model List<ProyMvcProyectoOnline205.Controllers.CarritoItem>

@{
    Layout = "_LayoutShop";
    var total = Model.Sum(x => x.Subtotal);
}

<div class="container mt-4">

    <h2 class="mb-4">🛒 Mi Carrito de Compras</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            Tu carrito está vacío.
        </div>

        <div class="text-center">
            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-primary btn-lg">
                ← Volver al catálogo
            </a>
        </div>
    }
    else
    {
        <!-- TABLA -->
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Precio</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-center">Subtotal</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Nombre</strong>
                                </td>
                                <td class="text-center">
                                    S/ @item.Precio
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary fs-6">
                                        @item.Cantidad
                                    </span>
                                </td>
                                <td class="text-center fw-bold text-success">
                                    S/ @item.Subtotal
                                </td>
                                <td class="text-center">
                                    <a asp-action="Quitar"
                                       asp-route-id="@item.IdProducto"
                                       class="btn btn-outline-danger btn-sm">
                                        ❌ Quitar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TOTAL -->
        <div class="card mt-4 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Total a pagar</h4>
                <h3 class="mb-0 text-success fw-bold">
                    S/ @total
                </h3>
            </div>
        </div>

        <!-- BOTONES -->
        <div class="d-flex justify-content-between mt-4 flex-wrap gap-2">

            <!-- SEGUIR COMPRANDO -->
            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-outline-primary btn-lg">
                ← Seguir comprando
            </a>

            <div>
                <!-- VACIAR -->
                <a asp-action="Limpiar"
                   class="btn btn-outline-warning btn-lg me-2">
                    🧹 Vaciar carrito
                </a>

                <!-- PAGAR -->
                <button class="btn btn-success btn-lg" disabled>
                    💳 Pagar con PayPal (Próximamente)
                </button>
            </div>
        </div>

        <!-- INFO -->
        <div class="alert alert-secondary mt-4">
            🔒 <strong>Pago seguro:</strong>
            Integración con <strong>PayPal</strong> (simulación académica).
        </div>
    }
</div>
    