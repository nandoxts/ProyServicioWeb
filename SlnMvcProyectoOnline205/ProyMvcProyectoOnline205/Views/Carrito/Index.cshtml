@model List<ProyMvcProyectoOnline205.Controllers.CarritoItem>

@{
    Layout = "_LayoutShop";
    ViewData["Title"] = "Mi carrito";
    var total = Model.Sum(x => x.Subtotal);
    var items = Model.Sum(x => x.Cantidad);
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="mb-1" style="font-weight:700;color:var(--app-text)">Mi carrito de compras</h2>
            <p class="text-muted mb-0">@items @(items == 1 ? "articulo" : "articulos") en tu carrito</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Seguir comprando
        </a>
    </div>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2" role="alert" style="border-radius:10px">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>@TempData["mensaje"]</span>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="app-card" style="text-align:center;padding:3rem 1.5rem">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--app-text-muted);margin-bottom:1rem">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <h4 style="font-weight:600">Tu carrito esta vacio</h4>
            <p class="text-muted">Explora el catalogo y agrega productos para empezar.</p>
            <a asp-controller="Home" asp-action="Index" class="app-btn app-btn--primary" style="margin-top:.5rem">
                Ir al catalogo
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- Items -->
            <div class="col-lg-8">
                <div class="app-card">
                    <div class="app-card__body" style="padding:0">
                        @foreach (var item in Model)
                        {
                            var imgSrc = !string.IsNullOrEmpty(item.RutaImagen)
                                ? item.RutaImagen
                                : "/lib/bootstrap/dist/css/bootstrap.min.css";
                            <div style="display:flex;gap:1rem;padding:1rem 1.25rem;border-bottom:1px solid var(--app-border);align-items:center">

                                <!-- Imagen -->
                                <div style="flex-shrink:0;width:72px;height:72px;border-radius:10px;background:var(--app-surface-alt);display:flex;align-items:center;justify-content:center;overflow:hidden">
                                    @if (!string.IsNullOrEmpty(item.RutaImagen))
                                    {
                                        <img src="@item.RutaImagen" alt="@item.Nombre" style="width:100%;height:100%;object-fit:cover" />
                                    }
                                    else
                                    {
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--app-text-muted)">
                                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                                            <circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                                        </svg>
                                    }
                                </div>

                                <!-- Info -->
                                <div style="flex:1;min-width:0">
                                    <div style="font-weight:600;color:var(--app-text)">@item.Nombre</div>
                                    <div class="text-muted" style="font-size:.85rem">S/ @item.Precio.ToString("N2") c/u</div>
                                    @if (item.StockMaximo.HasValue && item.Cantidad >= item.StockMaximo.Value)
                                    {
                                        <span class="app-pill app-pill--warning" style="margin-top:.25rem">Stock maximo alcanzado</span>
                                    }
                                </div>

                                <!-- Cantidad: -/+ -->
                                <div style="display:flex;align-items:center;gap:.25rem;border:1px solid var(--app-border);border-radius:8px;padding:.15rem">
                                    <a asp-action="Actualizar" asp-route-id="@item.IdProducto" asp-route-cantidad="@(item.Cantidad - 1)"
                                       class="app-btn app-btn--ghost app-btn--sm" style="border:0;padding:.25rem .5rem"
                                       title="Disminuir">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                    </a>
                                    <span style="min-width:28px;text-align:center;font-weight:600">@item.Cantidad</span>
                                    <a asp-action="Actualizar" asp-route-id="@item.IdProducto" asp-route-cantidad="@(item.Cantidad + 1)"
                                       class="app-btn app-btn--ghost app-btn--sm" style="border:0;padding:.25rem .5rem"
                                       title="Aumentar">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                    </a>
                                </div>

                                <!-- Subtotal -->
                                <div style="min-width:90px;text-align:right;font-weight:700;color:var(--app-text)">
                                    S/ @item.Subtotal.ToString("N2")
                                </div>

                                <!-- Quitar -->
                                <a asp-action="Quitar" asp-route-id="@item.IdProducto"
                                   class="app-btn app-btn--ghost" title="Quitar"
                                   onclick="return confirm('Quitar este producto del carrito?')">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    </svg>
                                </a>
                            </div>
                        }
                    </div>
                </div>

                <div style="display:flex;justify-content:space-between;margin-top:1rem">
                    <a asp-action="Limpiar" class="app-btn app-btn--ghost"
                       onclick="return confirm('Vaciar el carrito completo?')">
                        Vaciar carrito
                    </a>
                </div>
            </div>

            <!-- Resumen -->
            <div class="col-lg-4">
                <div class="app-card" style="position:sticky;top:1rem">
                    <div class="app-card__header">Resumen del pedido</div>
                    <div class="app-card__body">
                        <div style="display:flex;justify-content:space-between;margin-bottom:.5rem">
                            <span class="text-muted">Articulos</span>
                            <span>@items</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;margin-bottom:.5rem">
                            <span class="text-muted">Subtotal</span>
                            <span>S/ @total.ToString("N2")</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;margin-bottom:1rem">
                            <span class="text-muted">Envio</span>
                            <span class="app-pill app-pill--success">Gratis</span>
                        </div>
                        <hr />
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem">
                            <span style="font-weight:700">Total</span>
                            <span style="font-weight:800;font-size:1.35rem;color:var(--app-brand-accent)">S/ @total.ToString("N2")</span>
                        </div>
                        <a asp-action="Checkout" class="app-btn app-btn--primary" style="width:100%;justify-content:center">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                                <line x1="1" y1="10" x2="23" y2="10"/>
                            </svg>
                            Finalizar compra
                        </a>
                        <p class="text-muted" style="font-size:.78rem;text-align:center;margin:.75rem 0 0">
                            Pago seguro · Integracion PayPal (sandbox)
                        </p>
                    </div>
                </div>
            </div>

        </div>
    }
</div>
