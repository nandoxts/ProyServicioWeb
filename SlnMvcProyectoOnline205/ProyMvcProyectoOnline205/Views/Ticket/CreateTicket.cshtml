@model ProyMvcProyectoOnline205.Models.Ticket

<h2>Crear Ticket</h2>

<form asp-action="CreateTicket" method="post">
    <div class="form-group mb-2">
        <label asp-for="Asunto"></label>
        <input asp-for="Asunto" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label asp-for="Descripcion"></label>
        <textarea asp-for="Descripcion" class="form-control"></textarea>
    </div>


    <button type="submit" class="btn btn-primary mt-3">
        Registrar Ticket
    </button>

    <a asp-action="IndexTicket" class="btn btn-secondary mt-3">
        Cancelar
    </a>
</form>
