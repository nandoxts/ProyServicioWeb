@model ProyMvcProyectoOnline205.Models.Ticket
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var rol = HttpContextAccessor.HttpContext?.Session.GetInt32("IdRol");
    bool esAdmin = rol == 1 || rol == 2;
    Layout = esAdmin ? "_LayoutAdmin" : "_LayoutShop";

    ViewData["Title"]        = "Nuevo ticket";
    ViewData["PageTitle"]    = "Nuevo ticket de soporte";
    ViewData["PageSubtitle"] = "Cuentanos el problema y nuestro equipo te respondera.";
    ViewData["PageCrumbs"]   = new[] { "Soporte", "Tickets", "Nuevo" };

    ViewData["PageActions"] = (Func<object, Microsoft.AspNetCore.Html.IHtmlContent>)(@<text>
        <a asp-action="IndexTicket" class="app-btn app-btn--ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver a la lista
        </a>
    </text>);

    var wrapperClass = esAdmin ? "" : "container py-4";
}

<div class="@wrapperClass">

    @if (esAdmin)
    {
        <partial name="Admin/_PageHeader" />
    }
    else
    {
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
            <div>
                <h2 class="mb-1" style="font-weight:700;color:var(--app-text)">Nuevo ticket de soporte</h2>
                <p class="text-muted mb-0">Cuentanos el problema y nuestro equipo te respondera.</p>
            </div>
            <a asp-action="IndexTicket" class="app-btn app-btn--ghost">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
                </svg>
                Volver a mis tickets
            </a>
        </div>
    }

    <div class="app-card" style="max-width:760px">
        <div class="app-card__header">Datos del ticket</div>
        <div class="app-card__body">
            <form asp-action="CreateTicket" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="app-form-group">
                    <label asp-for="Asunto" class="app-form-label">Asunto</label>
                    <input asp-for="Asunto" class="form-control" placeholder="Ej. No me llego mi pedido" maxlength="120" required />
                </div>

                <div class="app-form-group">
                    <label asp-for="Descripcion" class="app-form-label">Descripcion</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="6"
                              placeholder="Describe con detalle lo que ocurrio. Incluye numero de pedido si aplica." required></textarea>
                </div>

                <div style="display:flex;justify-content:flex-end;gap:.6rem;margin-top:1rem">
                    <a asp-action="IndexTicket" class="app-btn app-btn--ghost">Cancelar</a>
                    <button type="submit" class="app-btn app-btn--primary">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                        </svg>
                        Enviar ticket
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>
